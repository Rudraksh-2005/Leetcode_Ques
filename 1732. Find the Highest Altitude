class Solution {
public:
    int largestAltitude(vector<int>& gain) {
        int ans=INT_MIN;
        int n=gain.size();

        vector<int>a(n+1,0);
        
        for(int i=1;i<=n;i++){
            a[i]=gain[i-1]+a[i-1];
            ans=max(ans,a[i]);
        }


        return ans<0?0:ans;

    }
};
