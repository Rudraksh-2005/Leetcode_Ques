class Solution {
public:
    int solve(int x){
        int sum=0;
        while(x>0){
            sum+=x%10;
            x/=10;
        }

        return sum;
    }
    int minElement(vector<int>& nums) {
        
        int n=nums.size();
        int mini=INT_MAX;

        for(int i=0;i<n;i++){
            int num=solve(nums[i]);
            mini=min(mini,num);
        }

        return mini;
    }
};
