class Solution {
public:
    void solve(vector<vector<int>>& grid, vector<vector<int>>& mat, int index){
        int m = grid[0].size();

        if(index % 2 == 0){
            for(int i = 0; i < m; i++){
                grid[index][i] = mat[index][(i + 1) % m];
            }
        }
        else{
            for(int i = 0; i < m; i++){
                grid[index][i] = mat[index][(i - 1 + m) % m];
            }
        }
    }

    bool areSimilar(vector<vector<int>>& mat, int k) {
        int n = mat.size();
        int m = mat[0].size();

        vector<vector<int>> grid = mat;

        k = k % m;

        for(int step = 0; step < k; step++){
            vector<vector<int>> temp = grid; 
            for(int i = 0; i < n; i++){
                solve(grid, temp, i);
            }
        }

        return grid == mat;
    }
};
