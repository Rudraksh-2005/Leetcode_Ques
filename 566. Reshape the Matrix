class Solution {
public:
    vector<vector<int>> matrixReshape(vector<vector<int>>& mat, int r, int c) {
        int n=mat.size();
        int m=mat[0].size();
        if(r*c!=m*n)return mat;

        
        vector<vector<int>>ans(r,vector<int>(c,1001));

        queue<int>q;

        for(int i=0;i<n;i++){
            for(int j=0;j<m;j++){
                q.push(mat[i][j]);
            }
        }

        
            for(int i=0;i<r;i++){
                for(int j=0;j<c;j++){
                    if(q.empty())break;
                    ans[i][j]=q.front();
                    q.pop();
                }
            }
        
        
        if(ans[r-1][c-1]==1001)return mat;
        return ans;
    }
};
