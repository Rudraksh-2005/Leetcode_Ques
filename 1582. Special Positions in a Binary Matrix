class Solution {
public:
    bool check(vector<vector<int>>& mat,int p, int q){
        for(int i=0;i<mat.size();i++){
            if(i==p)continue;
            else if(mat[i][q]!=0){
                return false;
            }
        }
        for(int j=0;j<mat[0].size();j++){
            if(j==q)continue;
            else if(mat[p][j]!=0){
                return false;
            }
        }


        return true;
    }
    int numSpecial(vector<vector<int>>& mat) {
        int cnt=0;

        for(int i=0;i<mat.size();i++){
            for(int j=0;j<mat[0].size();j++){
                if(mat[i][j]==1){
                    if(check(mat,i,j)){
                        cnt++;
                    }
                }
            }
        }

        return cnt;
    }
};
