class Solution {
public:
    
    char findKthBit(int n, int k) {
        
        string ans="0";
        if(n==1)return ans[0];

        for(int i=2;i<=n;i++){
            string s2=ans;
            transform(s2.begin(), s2.end(), s2.begin(),
                   [](char c) { return c == '0' ? '1' : '0'; });
            ans= ans+ '1';
            reverse(s2.begin(),s2.end());
            ans+=s2;
        }

        

        return ans[k-1];

    }
};
