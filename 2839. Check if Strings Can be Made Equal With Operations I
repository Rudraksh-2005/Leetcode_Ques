class Solution {
public:
    bool canBeEqual(string s1, string s2) {
        
        for(int i=0;i<s1.length()/2;i++){
            if(s1[i]==s2[i])continue;
            else if(s1[i]!=s2[i+2])return false;

        }
        for(int i=s1.length()/2;i<s1.length();i++){
            if(s1[i]==s2[i])continue;
            else if(s1[i]!=s2[i-2])return false;
        }

        return true;
    }
};
