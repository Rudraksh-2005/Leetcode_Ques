class Solution {
public:
    int minimumCost(vector<int>& cost) {
        int n=cost.size();
        sort(cost.begin(),cost.end());
        int ans=0;
        

        int i=n-1;
        int cnt=1;
        
        while(i>=0){
            if(cnt>2){
                cnt=1;
            }
            else{
                ans+=cost[i];
                cnt++;
            }
            i--;
        }
        return ans;
    }
};
