class Solution {
public:
    vector<int> leftRightDifference(vector<int>& nums) {
        int n=nums.size();
        vector<int>ans(n);


        if(n==1)return {0};
        
        vector<int>psum(n,0);
        psum[0]=nums[0];
        for(int i=1;i<n;i++){
            psum[i]=nums[i]+psum[i-1];
        }

        vector<int>ssum(n,0);
        ssum[n-1]=nums[n-1];

        for(int i=n-2;i>=0;i--){
            ssum[i]=nums[i]+ssum[i+1];
        }

        for(int i=0;i<n;i++){
            if(i==0){
                ans[0]=ssum[1];
            }
            else if(i==n-1){
                ans[n-1]=psum[n-2];
            }
            else{
                ans[i]=abs(psum[i-1]-ssum[i+1]);
            }
            
        }

        return ans;
    }
};
