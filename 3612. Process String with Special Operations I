class Solution {
public:
    string processStr(string s) {
        int n=s.length();
        string result="";

        for(int i=0;i<n;i++){
            if(s[i]=='*'){
                result=result.substr(0,result.size()-1);
            }
            else if(s[i]=='#'){
                result=result+result;
            }
            else if(s[i]=='%'){
                reverse(result.begin(),result.end());
            }
            else{
                result+=s[i];
            }
        }

        return result;
    }
};
