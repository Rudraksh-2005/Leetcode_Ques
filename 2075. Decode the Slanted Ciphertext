class Solution {
public:
    string decodeCiphertext(string encodedText, int rows) {
        int m=encodedText.length()/rows;
        vector<vector<string>>ans(rows,vector<string>(m,""));

        int a=0;
        for(int i=0;i<rows;i++){
            for(int j=0;j<m;j++){
                ans[i][j]=encodedText[a++];
            }
        }

        
        string d="";
        for(int j=0;j<m;j++){
            if(ans[0][j]!=""){
                int p=0,q=j;
                while(p<rows && q<m){
                    d+=ans[p][q];
                    p++;
                    q++;
                }
                

            }
        }

        while(!d.empty() && d.back()==' '){
            d.pop_back();
        }
        return d;
    }
};
