class Solution {
public:
    int numberOfSpecialChars(string word) {
        int n=word.length();
        unordered_map<char,int>mpp;
        set<char>st;

        int cnt=0;
        sort(word.rbegin(),word.rend());
        for(int i=0;i<n;i++){
            if(islower(word[i])){
                mpp[word[i]]++;
            }
            if(isupper(word[i])){
                if(mpp.find(tolower(word[i]))!=mpp.end()){
                    st.insert(word[i]);
                    mpp[tolower(word[i])]--;
                    if(mpp[tolower(word[i])]==0){
                        mpp.erase(tolower(word[i]));
                    }
                }
            }
            
            
        }
        return st.size();
    }
};
