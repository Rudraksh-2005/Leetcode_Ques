class Solution {
public:
    int findLengthOfLCIS(vector<int>& nums) {
        int maxi=1;
        int cnt=1;
        int i=0;


        while(i<nums.size()-1){
            if(nums[i]<nums[i+1]){
                cnt++;
               
            }
            else{
                cnt=1;

            }
            maxi=max(maxi,cnt);
            i++;
        }

        return maxi;
    }
};
