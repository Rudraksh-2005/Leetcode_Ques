class Solution {
public:
    vector<int> singleNumber(vector<int>& nums) {
        int xr = 0;

        for(int num : nums) {
            xr ^= num;
        }

        // safe rightmost set bit
        unsigned int right = xr & (-(unsigned int)xr);

        int b1 = 0, b2 = 0;

        for(int num : nums) {
            if(num & right) {
                b1 ^= num;
            } else {
                b2 ^= num;
            }
        }

        return {b1, b2};
    }
};
